# Copy this file to .env and fill in your own values.
# .env is listed in .gitignore and will never be committed to Git.

# --- Database ---
# Used by docker-compose.yml to configure the MySQL container and the app.
# For local development the defaults below match the docker-compose.yml values.
DB_URL=jdbc:mysql://localhost:3306/cardvault?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=cardvault
DB_PASSWORD=cardvault123

# --- JWT ---
# Must be at least 32 characters. Generate one with: openssl rand -hex 32
JWT_SECRET=replace_with_at_least_32_random_chars_here_xxxxxx
JWT_EXPIRATION=86400000

# --- Card Encryption ---
# Must be EXACTLY 32 characters (AES-256 key). Generate one with: openssl rand -hex 16
CARD_ENCRYPTION_KEY=replace_with_exactly_32_chars!!!!
